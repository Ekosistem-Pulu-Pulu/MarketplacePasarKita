APP_PORT=3002
APP_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=""
DB_NAME=pasarkita_marketplace

API_GATEWAY_BASE_URL=http://localhost:3000
ENABLE_GATEWAY_FORWARD=false
JWT_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# Daftar origin eksplisit dipisahkan koma. Wildcard (*) ditolak.
CORS_ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1m
AUTH_RATE_LIMIT_MAX=10
ENABLE_DOCS=false

# Seeder hanya untuk development. Isi password kuat jika diaktifkan.
SEED_DATABASE=false
SEED_USER_PASSWORD=
