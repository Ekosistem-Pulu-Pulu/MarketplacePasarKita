APP_PORT=3002
APP_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=""
DB_NAME=pasarkita_marketplace

API_GATEWAY_BASE_URL=http://localhost:3000
ENABLE_GATEWAY_FORWARD=false
JWT_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# Daftar origin eksplisit dipisahkan koma. Wildcard (*) ditolak; entry kosong
# atau port non-numeric akan di-skip otomatis saat runtime (bukan error).
#
# Loopback pair di-expand saat runtime:
#   http://localhost:<port>   <-->   http://127.0.0.1:<port>
# Aturan: protokol http://; port numeric 1-65535; tidak menyentuh
# https://localhost, IPv6, atau origin di luar loopback IPv4. Setelah
# mengubah nilai di sini, restart BE (Fiber tidak hot-reload origin list).
CORS_ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1m
AUTH_RATE_LIMIT_MAX=10
ENABLE_DOCS=false

# Seeder hanya untuk development. Isi password kuat jika diaktifkan.
SEED_DATABASE=false
SEED_USER_PASSWORD=

# -------------------------------------------------
# PHASE 4 — STORAGE: abstraction untuk upload gambar produk.
# STORAGE_PROVIDER: mock | local | s3 | minio | r2 | cloudinary
# Mode default "mock" menulis ke ./uploads dan disajikan via /uploads/*.
# -------------------------------------------------
STORAGE_PROVIDER=mock
STORAGE_LOCAL_ROOT=./uploads
STORAGE_PUBLIC_URL=

# Untuk S3 / MinIO / R2 (AWS Signature V4)
STORAGE_BASE_URL=
STORAGE_BUCKET=
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Untuk Cloudinary
STORAGE_CLOUD_NAME=
